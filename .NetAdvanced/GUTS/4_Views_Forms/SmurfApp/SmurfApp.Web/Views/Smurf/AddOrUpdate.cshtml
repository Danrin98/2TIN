@model AddOrUpdateSmurfViewModel
@{
    ViewData["Title"] = "Smurf a smurf";
}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Smurf a smurf</h3>
                </div>
                <div class="card-body">
                    <!--- TODO: show validation summary if ViewData.ModelState is invalid -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                    <div class="alert alert-danger" role="alert" asp-validation-summary="All"></div>
                    }
                    <form asp-action="AddOrUpdate" method="post" role="form">
                        <!--- TODO: remember the Smurf Id in an hidden input -->
                        <input type="hidden" asp-for="Smurf.Id" class="form-control" />
                        <!--- TODO: label and input for Name -->
                        <div class="mb-3">
                            <label asp-for="Smurf.Name" class="form-label"></label>
                            <input asp-for="Smurf.Name" class="form-control" placeholder="Enter smurf name" />
                            <!--- TODO: show validation errors in span -->
                            <span asp-validation-for="Smurf.Name" class="text-danger small"></span>
                        </div>

                        <!--- TODO: label and input for Age -->
                        <div class="mb-3">
                            <label asp-for="Smurf.Age" class="form-label"></label>
                            <input asp-for="Smurf.Age" class="form-control" placeholder="Enter age" />
                            <!--- TODO: show validation errors in span -->
                            <span asp-validation-for="Smurf.Age" class="text-danger small"></span>
                        </div>

                        <!--- TODO: label and input for Image Url -->
                        <div class="mb-3">
                            <label asp-for="Smurf.ImageUrl" class="form-label"></label>
                            <input asp-for="Smurf.ImageUrl" class=" form-control" type="url" placeholder="https://charactersdb.com/wp-content/uploads/image.jpg" />
                            <!--- TODO: show validation errors in span -->
                            <span asp-validation-for="Smurf.ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <!--- TODO: label and select for Category -->
                            <label asp-for="Smurf.Category" class="form-label"></label>
                            <select asp-for="Smurf.Category" class="form-select" asp-items="Model.AllCategories">
                                <option value="">-- Select a category --</option>
                            </select>
                            <!--- TODO: show validation errors in span -->
                            <span asp-validation-for="Smurf.Category" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <!--- TODO: link to home page -->
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>