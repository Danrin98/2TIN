@model Smurf
<div class="col">
    <div class="card h-100 shadow-sm">
        <img src="@Model.ImageUrl" alt="@Model.Id" />
        <div class="card-body d-flex flex-column">
            <h5 class="card-title mb-1">@Model.Name</h5>
            <p class="mb-1">
                <span class="badge bg-primary">@Model.Category</span>
                <small class="text-muted ms-2">Age: @Model.Age</small>
            </p>
            <div class="mt-auto">
                <a class="btn btn-outline-primary btn-sm w-100" asp-controller="Smurf" asp-action="AddOrUpdate" asp-route-id="@Model.Id">Details</a>
            </div>
        </div>
    </div>
</div>
