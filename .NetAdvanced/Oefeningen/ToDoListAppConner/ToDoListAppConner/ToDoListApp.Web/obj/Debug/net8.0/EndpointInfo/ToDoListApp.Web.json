{
  "openapi": "3.0.4",
  "info": {
    "title": "ToDoListApp.Web",
    "version": "1.0"
  },
  "paths": {
    "/ToDoList/Search": {
      "get": {
        "tags": [
          "ToDoList"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "ToDoList"
        ],
        "parameters": [
          {
            "name": "TitleFilter",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ToDoLists",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/ToDoList"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ToDoList/Details/{id}": {
      "get": {
        "tags": [
          "ToDoList"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "ToDoList"
        ],
        "parameters": [
          {
            "name": "List.Id",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "List.Title",
            "in": "query",
            "required": true,
            "schema": {
              "minLength": 4,
              "type": "string"
            }
          },
          {
            "name": "List.Items",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/ToDoItem"
              }
            }
          },
          {
            "name": "ListId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "NewItemDescription",
            "in": "query",
            "required": true,
            "schema": {
              "minLength": 4,
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ToDoList/MarkAsDone": {
      "post": {
        "tags": [
          "ToDoList"
        ],
        "parameters": [
          {
            "name": "itemId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "listId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "IsDone",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/todolists/{id}": {
      "get": {
        "tags": [
          "ToDoLists"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoList"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoList"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoList"
                }
              }
            }
          }
        }
      }
    },
    "/api/todolists": {
      "post": {
        "tags": [
          "ToDoLists"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddNewToDoListModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddNewToDoListModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddNewToDoListModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoList"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoList"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoList"
                }
              }
            }
          }
        }
      }
    },
    "/api/todolists/{listId}/items/{id}": {
      "put": {
        "tags": [
          "ToDoLists"
        ],
        "parameters": [
          {
            "name": "listId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "isDone",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoItem"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoItem"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToDoItem"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddNewToDoListModel": {
        "required": [
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 4,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ToDoItem": {
        "required": [
          "description"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "readOnly": true
          },
          "description": {
            "minLength": 4,
            "type": "string",
            "readOnly": true
          },
          "isDone": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ToDoList": {
        "required": [
          "title"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "readOnly": true
          },
          "title": {
            "minLength": 4,
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToDoItem"
            },
            "nullable": true,
            "readOnly": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}