@model CaffeineWarningViewModel?

<div class="col-lg-12 p-4">
    @if (Model is not null)
    {
        <div class="d-flex justify-content-between align-items-center bg-info p-2">
            <div>
                <strong>Caffeine Warning:</strong> Today's estimated campus intake is @Model.TotalMg mg.
                <partial name="_Badge" model="@Model.CurrentLevel" />
            </div>
            @if (Model.CurrentLevel > DangerLevel.Manageable)
            {
                <span class="text-white">PXL Hasselt hydration squad is watching.</span>
            }
        </div>

    }
    else
    {
        <div class="d-flex justify-content-between align-items-center p-2 border border-warning">
            Strange... No caffeine data found for today.
        </div>
    }
</div>