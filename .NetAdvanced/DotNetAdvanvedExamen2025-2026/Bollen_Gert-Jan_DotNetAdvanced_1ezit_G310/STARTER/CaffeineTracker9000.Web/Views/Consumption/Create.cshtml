@model NewConsumptionViewModel
@{
    ViewData["Title"] = "Log a caffeine consumption";
}

<h1>Log a caffeine consumption</h1>
<p class="text-muted">Record who, where and when that caffeine shot happened.</p>

<form asp-action="Create" method="post" class="row g-3">
    @* Tip: You can access a nested property in tag helpers by using dot notation, e.g. Consumption.UserName *@
    <div class="col-md-6">
        <label asp-for="Consumption.UserName" class="form-label"></label>
        <input asp-for="Consumption.UserName" class="form-control" />
        <span asp-validation-for="Consumption.UserName" class=" text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Consumption.Email" class="form-label"></label>
        <input asp-for="Consumption.Email" class="form-control" />
        <span asp-validation-for="Consumption.Email" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Consumption.Location" class="form-label">Location</label>
        <input asp-for="Consumption.Location" class="form-control" placeholder="PXL Hasselt campus spot" />
        <span asp-validation-for="Consumption.Location" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DrinkSelectList.SelectedValue" class="form-label">Drink</label>
        <select asp-for="DrinkSelectList.SelectedValue" class="form-select"></select>
        <span asp-validation-for="DrinkSelectList.SelectedValue" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button class="btn btn-primary">Save consumption</button>
        <a asp-controller="Drinks" asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>

